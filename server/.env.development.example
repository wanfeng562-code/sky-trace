APP_NAME=Sky-Trace-Server
APP_ENV=development
APP_PROFILE=development
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

# Unified collector mode
DATA_SOURCE_MODE=hybrid
REALTIME_SOURCE=opensky
REALTIME_FALLBACK_TO_MOCK=true

# OpenSky polling in development:
# use_active_window=false → flat 90 s polling all day
# ~960 calls/day × 4 pts = 3840 pts/day  (budget: 4000 pts/day for registered users)
# To enable burst window (e.g. 15 s active / 90 s idle), set USE_ACTIVE_WINDOW=true
DEV_REALTIME_USE_ACTIVE_WINDOW=false
DEV_REALTIME_ACTIVE_INTERVAL_SECONDS=15
DEV_REALTIME_IDLE_INTERVAL_SECONDS=90
DEV_REALTIME_ACTIVE_START_HOUR=8
DEV_REALTIME_ACTIVE_START_MINUTE=0
DEV_REALTIME_DAILY_BUDGET_CALLS=1000

# Development profile frequencies
DEV_REALTIME_INTERVAL_SECONDS=30
DEV_ENVIRONMENT_INTERVAL_SECONDS=300
DEV_COMMERCIAL_INTERVAL_SECONDS=86400

# Release profile frequencies (not used unless APP_PROFILE=release)
RELEASE_REALTIME_INTERVAL_SECONDS=10
RELEASE_ENVIRONMENT_INTERVAL_SECONDS=120
RELEASE_COMMERCIAL_INTERVAL_SECONDS=86400

HTTP_TIMEOUT_SECONDS=30

# OpenSky (main real-time source)
# Leave OPENSKY_BBOX empty for global coverage (~6000 aircraft).
# Restrict to a region with: SW-lat,NE-lat,SW-lon,NE-lon  e.g. 21.0,26.0,108.0,116.0
OPENSKY_BASE_URL=https://opensky-network.org/api
OPENSKY_USERNAME="your-opensky-username"   # Register at: https://opensky-network.org/
OPENSKY_PASSWORD="your-opensky-password"
OPENSKY_BBOX=

# AirLabs bulk enrichment (1 call/day covers ALL flights in bbox)
# Free tier: 1,000 requests/month → ~30 calls/month at default cadence.
# Register at: https://airlabs.co/
AIRLABS_API_KEY="your-airlabs-api-key"  # Register at: https://airlabs.co/
AIRLABS_BASE_URL=https://airlabs.co/api/v9
# Cache TTL (hours): records older than this trigger a fresh bulk call.
# 24 h aligns with the daily refresh cadence.
AIRLABS_ENRICH_TTL_HOURS=24

# Environment layer — OpenWeather
# Register at: https://openweathermap.org/api  (Free tier: 60 req/min)
OPENWEATHER_API_KEY="your-openweather-api-key"  # Register at: https://openweathermap.org/api
OPENWEATHER_CITY=Guangzhou
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
OPENWEATHER_LAT=23.1
OPENWEATHER_LON=113.3
# Comma-separated IATA codes for multi-hub weather collection.
# Leave empty to use the built-in default list of 20 global aviation hubs.
# Example: OPENWEATHER_HUBS=CAN,HKG,PEK,SIN,LHR,JFK
OPENWEATHER_HUBS=

SQLITE_PATH=./data/sky_trace.db
CORS_ALLOW_ORIGINS=http://localhost:5173
WS_HEARTBEAT_SECONDS=20

HTTP_PROXY=http://127.0.0.1:your proxy_port 