# Copy this file to .env and fill your keys.

# OpenSky (optional for low-frequency anonymous access; recommended to fill)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
OPENSKY_BBOX=21.0,26.0,108.0,116.0

# AeroDataBox (RapidAPI)
AERODATABOX_API_KEY=
AERODATABOX_API_HOST=aerodatabox.p.rapidapi.com
AERODATABOX_BASE_URL=https://aerodatabox.p.rapidapi.com
# Update date range to valid local datetime per API docs.
AERODATABOX_TEST_PATH=flights/airports/iata/SZX/2026-04-13T00:00/2026-04-13T12:00
AERODATABOX_WITH_LEG=true

# Aviationstack
AVIATIONSTACK_ACCESS_KEY=
AVIATIONSTACK_BASE_URL=http://api.aviationstack.com/v1

# Mapbox
# Removed from automated tests due to IP-based registration restriction.

# OpenWeatherMap
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Guangzhou
